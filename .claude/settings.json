{
  "permissions": {
    "allow": [
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run format:*)",
      "Bash(npm run type-check:*)",
      "Bash(npm install:*)",
      "Bash(npm audit:*)",
      "Bash(npx tsc:*)",
      "Bash(npx next:*)",
      "Bash(npx playwright:*)",
      "Bash(npm run test:*)",
      "Bash(ls:*)",
      "Bash(npx cdk:*)",
      "Bash(npx ts-node:*)",
      "Bash(aws sts:*)",
      "Bash(aws dynamodb:*)",
      "Bash(aws s3:*)",
      "Bash(aws cognito-idp:*)",
      "Bash(aws cloudformation:*)",
      "Bash(node .pipeline/scripts/checkpoint.mjs:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // \"\"' | { read -r f; case \"$f\" in *.pipeline/state.json) printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"state.json은 checkpoint.mjs 서브커맨드로만 수정하세요. CLAUDE.md 정책: node .pipeline/scripts/checkpoint.mjs check <stage> <args>\"}}' ;; *) exit 0 ;; esac; }",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
